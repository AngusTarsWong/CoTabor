{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "target": "es2022",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@cotabor/core": ["src/core"],
      "@cotabor/driver": ["src/driver"],
      "@cotabor/shared": ["src/shared"],
      "@cotabor/web": ["src/web"],
      "@cotabor/vision": ["src/vision"],
      "@cotabor/playground": ["src/playground-lib"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*", "apps/**/*"],
  "exclude": ["node_modules", "dist", "packages", "midsense"]
}
