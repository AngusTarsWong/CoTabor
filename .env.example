# 大模型服务商 (例如: openai, deepseek, aliyun, anthropic)
VITE_LLM_PROVIDER=openai

# 大模型 API Key (请在此填入你的真实 Key)
VITE_LLM_API_KEY=your_api_key_here

# 大模型 Base URL (如果是国内代理或自定义服务，请在此配置，否则可留空)
VITE_LLM_BASE_URL=https://api.openai.com/v1

# 默认使用的大模型版本 (例如: gpt-4o, deepseek-chat, qwen-max)
VITE_LLM_MODEL=gpt-4o
