# ==========================================
# CoTabor 全局环境变量配置 (.env)
# 复制此文件为 .env 并在本地填写你的真实 Key
# 这是统一管理配置的地方，rsbuild 和脚本会自动读取
# ==========================================

# ==========================================
# 1. 基础大模型配置 (全局默认兜底)
# ==========================================
VITE_LLM_PROVIDER=openai
VITE_LLM_BASE_URL=https://api.openai.com/v1
VITE_LLM_MODEL=gpt-4o
VITE_LLM_API_KEY=your_openai_api_key_here

# ==========================================
# 2. Midsense 感知层配置 (视觉抢救 / 精准定位)
# 注意：若不填该 API Key，系统将回退使用基础底层 DOM 点击引擎 (NativeAdapter)
# ==========================================
VITE_MIDSENSE_API_KEY=your_midsense_api_key_here
VITE_MIDSENSE_BASE_URL=https://api.example.com/v1
VITE_MIDSENSE_MODEL=ui-tars-7b

# ==========================================
# 3. 各路大脑独立进阶配置 (可选)
# 如果留空，将自动使用上方「1. 基础大模型配置」的参数
# 你可以在这里让 Planner 用最聪明的闭源模型，而 Watchdog 用开源便宜的模型
# ==========================================

# Planner 节点 (负责核心规划)
# VITE_LLM_PLANNER_PROVIDER=openai
# VITE_LLM_PLANNER_API_KEY=
# VITE_LLM_PLANNER_BASE_URL=
# VITE_LLM_PLANNER_MODEL=gpt-4o
# VITE_LLM_PLANNER_ENABLE=true

# Cortex 节点 (复杂视觉补充描述等)
# VITE_LLM_CORTEX_PROVIDER=openai
# VITE_LLM_CORTEX_API_KEY=
# VITE_LLM_CORTEX_BASE_URL=
# VITE_LLM_CORTEX_MODEL=gpt-4o
# VITE_LLM_CORTEX_ENABLE=true

# Watchdog 节点 (负责动作审计犬与结果提取)
# VITE_LLM_WATCHDOG_PROVIDER=openai
# VITE_LLM_WATCHDOG_API_KEY=
# VITE_LLM_WATCHDOG_BASE_URL=
# VITE_LLM_WATCHDOG_MODEL=gpt-4o-mini
# VITE_LLM_WATCHDOG_ENABLE=true

# ==========================================
# 4. 调试与控制开关
# ==========================================
VITE_DEBUG_MODE=true
VITE_MEDIA_CAPTURE_ON_FAIL=true

# ==========================================
# 5. 飞书 (Lark) App 配置
# 在飞书开放平台创建应用后获取：https://open.feishu.cn/app
# ==========================================
VITE_LARK_APP_ID=cli_your_app_id_here
VITE_LARK_APP_SECRET=your_app_secret_here

# ==========================================
# 6. 飞书用户身份 Token（仅 Node.js 脚本环境使用）
# 浏览器插件环境：通过 Options 页扫码授权，Token 自动存入 chrome.storage.local，无需填写此处
# Node.js 脚本环境：运行 tsx scripts/lark-login.ts 扫码登录，
#   登录成功后终端会打印以下四个值，复制到此处即可
# 注意：Token 属于个人凭证，请勿提交到版本库（.lark_auth.json 已加入 .gitignore）
# ==========================================
LARK_ACCESS_TOKEN=
LARK_REFRESH_TOKEN=
LARK_EXPIRES_AT=
LARK_REFRESH_EXPIRES_AT=

# ==========================================
# 7. Notion OAuth 配置（使用 Notion 作为记忆后端时填写）
# 在 Notion 开发者页面创建 Integration 后获取
# ==========================================
VITE_NOTION_CLIENT_ID=
VITE_NOTION_CLIENT_SECRET=

# ==========================================
# 8. Notion 记忆后端（Node.js 脚本模式专用）
# 浏览器插件：通过 Options 页 "一键构建" 按钮完成初始化，无需手动填写
# 脚本模式：只需填写以下两个字段，然后运行一次 `npm run tool:init-notion`
#   脚本会自动创建/发现 L1/L2/L3 等数据库，并将配置保存到 .notion_config.local.json
# ==========================================
VITE_NOTION_API_KEY=

# 你希望作为 AI 记忆根目录的 Notion 页面 URL（和插件里 "步骤 2" 填写的母文档一致）
NOTION_PARENT_PAGE_URL=https://www.notion.so/My-Brain-Page-xxxxx
