# ==========================================
# 基础服务配置 (Base Configuration)
# ==========================================
# 所有模型默认继承此配置，除非在下方特定档位中覆盖 (Fallback Strategy)
# 参考 Midscene 的配置方式，支持不同服务商混用

# 默认服务商 (openai, deepseek, aliyun, anthropic)
VITE_LLM_PROVIDER=openai
# 默认 API Key
VITE_LLM_API_KEY=your_api_key_here
# 默认 Base URL
VITE_LLM_BASE_URL=https://api.openai.com/v1
# 默认模型 (兜底用)
VITE_LLM_MODEL=gpt-4o

# ==========================================
# 1. 深度思考模型 (Planner & Replanner)
# ==========================================
# 核心能力：复杂逻辑推理、任务拆解
# 场景：Graph 中的 Planner 节点、Replanner 节点

# 启用状态
VITE_LLM_PLANNER_ENABLE=true
# 指定模型 (推荐 o1-mini, deepseek-reasoner)
VITE_LLM_PLANNER_MODEL=o1-mini
# [可选] 覆盖基础配置 (例如使用 DeepSeek 专用 Key)
# VITE_LLM_PLANNER_API_KEY=sk-special-key-for-reasoning
# VITE_LLM_PLANNER_BASE_URL=https://api.deepseek.com/v1
# VITE_LLM_PLANNER_PROVIDER=deepseek

# ==========================================
# 2. 中等思考+多模态模型 (Cortex)
# ==========================================
# 核心能力：视觉理解、错误分析、战术调整
# 场景：Graph 中的 Cortex 节点

VITE_LLM_CORTEX_ENABLE=true
VITE_LLM_CORTEX_MODEL=gpt-4o
# [可选] 覆盖基础配置
# VITE_LLM_CORTEX_API_KEY=...
# VITE_LLM_CORTEX_BASE_URL=...

# ==========================================
# 3. 基础多模态模型 (Watchdog)
# ==========================================
# 核心能力：快速截图验证、低成本检查
# 场景：Graph 中的 Watchdog 节点

VITE_LLM_WATCHDOG_ENABLE=true
VITE_LLM_WATCHDOG_MODEL=gpt-4o-mini
# [可选] 覆盖基础配置
# VITE_LLM_WATCHDOG_API_KEY=...
# VITE_LLM_WATCHDOG_BASE_URL=...
