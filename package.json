{
  "name": "CoTabor",
  "version": "0.0.1",
  "description": "A Chrome extension automation tool",
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "watch": "rsbuild build --watch",
    "preview": "rsbuild preview",
    "debug": "tsx scripts/debug-agent.ts",
    "ext:debug": "tsx scripts/run-extension-debug.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "tsx scripts/test-all.ts",
    "test:watch": "tsx --watch scripts/test-all.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.3.1",
    "@midscene/web": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@orama/orama": "^3.1.18",
    "@page-agent/page-controller": "^1.5.7",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "chrome-remote-interface": "^0.34.0",
    "idb": "^8.0.3",
    "jsdom": "^29.0.1",
    "openai": "^6.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.0.1",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.0.1",
    "@types/chrome": "^0.0.268",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "dotenv": "^17.3.1",
    "fake-indexeddb": "^6.2.5",
    "puppeteer": "^24.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2"
  }
}
