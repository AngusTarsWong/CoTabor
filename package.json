{
  "name": "CoTabor",
  "version": "1.0.0",
  "description": "A Chrome extension automation tool",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "build:page-agent": "node scripts/build-page-agent.js",
    "build": "npm run build:page-agent && rsbuild build",
    "watch": "rsbuild build --watch",
    "preview": "rsbuild preview",
    "typecheck": "tsc --noEmit",
    "i18n:check": "tsx scripts/i18n-check.ts",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "task:run": "tsx scripts/tasks/run.ts",
    "test": "node --experimental-strip-types --import ./scripts/tests/setup.ts --test scripts/tests/unit/*.test.ts",
    "test:unit": "node --experimental-strip-types --import ./scripts/tests/setup.ts --test scripts/tests/unit/*.test.ts",
    "test:unit:watch": "node --experimental-strip-types --import ./scripts/tests/setup.ts --test --watch scripts/tests/unit/*.test.ts",
    "test:integration": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/*.test.ts",
    "test:live:news": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/multi-news-dag.test.ts",
    "test:live:e2e": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/e2e.test.ts",
    "test:live:all": "npm run test:live:news && npm run test:live:e2e",
    "tool:debug": "tsx scripts/tools/debug-agent.ts",
    "tool:ext-debug": "tsx scripts/tools/ext-debug.ts",
    "tool:init-notion": "tsx scripts/tools/init-notion.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/x": "^2.5.0",
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.3.1",
    "@midscene/web": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@orama/orama": "^3.1.18",
    "@page-agent/page-controller": "^1.5.7",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "antd": "^6.3.6",
    "chrome-remote-interface": "^0.34.0",
    "i18next": "^26.0.8",
    "i18next-resources-to-backend": "^1.2.1",
    "idb": "^8.0.3",
    "jsdom": "^29.0.1",
    "openai": "^6.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "turndown": "^7.2.3",
    "wink-bm25-text-search": "^3.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.0.1",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.0.1",
    "@types/chrome": "^0.0.268",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "dotenv": "^17.3.1",
    "fake-indexeddb": "^6.2.5",
    "puppeteer": "^24.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2"
  }
}
