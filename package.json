{
  "name": "CoTabor",
  "version": "1.0.0",
  "description": "A Chrome extension automation tool",
  "author": "CoTabor Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cotabor/cotabor.git"
  },
  "bugs": {
    "url": "https://github.com/cotabor/cotabor/issues"
  },
  "homepage": "https://github.com/cotabor/cotabor#readme",
  "keywords": [
    "chrome-extension",
    "agent",
    "automation",
    "mcp",
    "langgraph",
    "browser-automation"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "build:page-agent": "node scripts/build-page-agent.js",
    "build": "npm run build:page-agent && rsbuild build",
    "watch": "rsbuild build --watch",
    "preview": "rsbuild preview",
    "typecheck": "tsc --noEmit",
    "i18n:check": "tsx scripts/i18n-check.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "task:run": "tsx scripts/tasks/run.ts",
    "test": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/unit/*.test.ts",
    "test:unit": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/unit/*.test.ts",
    "test:unit:watch": "tsx --import ./scripts/tests/setup.ts --test --watch scripts/tests/unit/*.test.ts",
    "test:integration": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/*.mock.test.ts",
    "test:live:all": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/*.live.test.ts",
    "test:alibaba-news-swarm": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/alibaba-news-swarm.live.test.ts",
    "test:alibaba-news-tri-source-swarm": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/alibaba-news-tri-source-swarm.live.test.ts",
    "test:midsense-vision": "tsx --import ./scripts/tests/setup.ts --test scripts/tests/integration/midsense-vision.live.test.ts",
    "tool:debug": "tsx scripts/tools/debug-agent.ts",
    "tool:ext-debug": "tsx scripts/tools/ext-debug.ts",
    "tool:init-notion": "tsx scripts/tools/init-notion.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/x": "^2.7.0",
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.3.1",
    "@midscene/web": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@orama/orama": "^3.1.18",
    "@page-agent/page-controller": "^1.5.7",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "antd": "^6.3.6",
    "chrome-remote-interface": "^0.34.0",
    "i18next": "^26.0.8",
    "i18next-resources-to-backend": "^1.2.1",
    "idb": "^8.0.3",
    "jsdom": "^29.0.1",
    "openai": "^6.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "react-markdown": "^9.1.0",
    "turndown": "^7.2.3",
    "wink-bm25-text-search": "^3.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.0.1",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.0.1",
    "@types/chrome": "^0.0.268",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fake-indexeddb": "^6.2.5",
    "puppeteer": "^24.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2"
  }
}
