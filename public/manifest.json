{
  "manifest_version": 3,
  "name": "CoTabor",
  "version": "1.0.0",
  "description": "A simple automation tool for Chrome",
  "permissions": [
    "sidePanel",
    "debugger",
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Open Side Panel"
  }
}
