{
  "manifest_version": 3,
  "name": "CoTabor",
  "version": "1.0.0",
  "description": "AI browser co-worker with three-layer memory, LangGraph agent, and MCP tool ecosystem.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "debugger",
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "identity",
    "management"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Open CoTabor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
